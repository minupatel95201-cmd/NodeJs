<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Files</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-300">
  <section>
     <!-- Task Form  -->
    
     <div class="flex justify-center items-center mt-5">
        <form action="/rename" method="post">
            <input type="text" placeholder="Old Name" name="old" value="<%= oldname %>" class="bg-gray-400 text-2xl rounded-xl block mb-2 px-3 py-1">
            <input type="text" placeholder="New File Name" name="new" class="bg-gray-400 text-2xl rounded-xl block mb-2 px-3 py-1">
            <input type="submit" value="Rename File" class="bg-orange-500 text-white w-full rounded-xl px-4 py-2 active:scale-95 active:bg-orange-200">
        </form>

     </div>
 

  </section>   
</body>
</html>